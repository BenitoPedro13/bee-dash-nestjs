# Postgres connection (Railway Postgres plugin provides DATABASE_URL directly;
# the DB_* vars below are only needed if you build the URL yourself)
DB_USER=
DB_PASSWORD=
DB_HOST=
DB_NAME=
DB_PORT=5432
DB_TYPE=postgres
DATABASE_URL=${DB_TYPE}://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}

PORT=3000
NODE_ENV=production
JWT_SECRET=

# AWS S3 (file storage)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_BUCKET_NAME=
